{
  "profileKey": "websites-apps",
  "displayName": "Websites and Apps",
  "description": "Profile-driven agent engine for public websites, member apps, church platforms, and related admin workflows.",
  "aliases": ["websites", "apps", "sites", "web-apps"],
  "agentPackagePath": "build_profiles/websites-apps.agents.md",
  "forceBackendRequired": true,
  "systemTypeOverride": "SYSTEM_BACKED",
  "systemSummary": "Public websites and member apps stay distinct while sharing backend ownership, roles, content, and operational workflows.",
  "dependencyNotes": [
    "Public site and member app route boundaries are mandatory.",
    "Backend ownership, roles, and validation must be defined before UI execution.",
    "Admin, commerce, and messaging work should not bypass Dan."
  ],
  "backendTriggerPatterns": [
    {
      "label": "member_app",
      "pattern": "\\b(member app|member portal|member dashboard|app home)\\b"
    },
    {
      "label": "church_content",
      "pattern": "\\b(sermon|sermons|prayer|prayer wall|watch live|beliefs|plan your visit|youth)\\b"
    }
  ],
  "seedModules": [
    "public_site",
    "member_app",
    "content_management",
    "role_permissions",
    "admin_workflows"
  ],
  "moduleRules": [
    {
      "patterns": ["\\bshop\\b", "\\bcheckout\\b", "\\bproduct(s)?\\b"],
      "add": ["product_catalog", "cart_checkout", "order_management"]
    },
    {
      "patterns": ["\\bprayer\\b", "\\bsermon(s)?\\b", "\\bevent(s)?\\b"],
      "add": ["church_content", "member_engagement"]
    },
    {
      "patterns": ["\\bmessage(s|ing)?\\b", "\\bchat\\b", "\\bnotification(s)?\\b"],
      "add": ["messaging", "notifications"]
    }
  ],
  "seedRoutes": [
    "/",
    "/watch-live",
    "/sermons",
    "/prayer",
    "/prayer-wall",
    "/give",
    "/beliefs",
    "/plan-your-visit",
    "/app",
    "/app/home"
  ],
  "routeRules": [
    {
      "patterns": ["\\byouth\\b"],
      "add": ["/lc-youth"]
    },
    {
      "patterns": ["\\bshop\\b", "\\bcheckout\\b", "\\bproduct(s)?\\b"],
      "add": ["/shop", "/product/:id", "/cart", "/checkout"]
    },
    {
      "patterns": ["\\badmin\\b", "\\bdashboard\\b"],
      "add": ["/admin"]
    }
  ],
  "pageGroups": ["public_pages", "member_app_pages", "admin_pages"],
  "userFlows": [
    "visitor_to_plan_visit",
    "visitor_to_watch_live",
    "member_login_to_app_home",
    "prayer_submission_to_approval"
  ],
  "accessBoundaries": ["public", "member", "admin"],
  "schemaTables": [
    "profiles",
    "roles",
    "permissions",
    "user_roles",
    "sermons",
    "events",
    "prayer_requests",
    "announcements",
    "media_assets"
  ],
  "schemaRules": [
    {
      "patterns": ["\\bshop\\b", "\\bcheckout\\b", "\\border(s)?\\b"],
      "add": ["products", "orders", "order_items"]
    },
    {
      "patterns": ["\\bmessage(s|ing)?\\b", "\\bchat\\b"],
      "add": ["conversations", "conversation_members", "messages"]
    }
  ],
  "relationships": [
    "profiles -> user_roles -> roles",
    "roles -> permissions",
    "sermons -> media_assets",
    "prayer_requests -> profiles",
    "orders -> order_items -> products"
  ],
  "validationRules": [
    "route_area_boundary_enforced",
    "role_based_access_enforced",
    "content_status_validation_enforced",
    "checkout_and_form_validation_enforced"
  ],
  "ownershipRules": [
    "members_edit_self_only_records",
    "admins_require_role_check_for_overrides",
    "public_content_changes_require_approval_path"
  ],
  "rolesPermissions": [
    "admin:full",
    "editor:content_and_media",
    "member:self_and_engagement",
    "visitor:public_read_only"
  ],
  "additionalComponents": [
    "hero_media",
    "announcement_stack",
    "sermon_cards",
    "prayer_request_form",
    "member_dashboard_shell"
  ],
  "componentRules": [
    {
      "patterns": ["\\bshop\\b", "\\bproduct(s)?\\b"],
      "add": ["product_grid", "checkout_summary"]
    },
    {
      "patterns": ["\\badmin\\b", "\\bdashboard\\b"],
      "add": ["admin_navigation", "role_guard"]
    }
  ],
  "additionalInteractions": [
    "member_auth_flow",
    "content_navigation",
    "prayer_submission_flow"
  ],
  "interactionRules": [
    {
      "patterns": ["\\bmessage(s|ing)?\\b", "\\bchat\\b"],
      "add": ["messaging_flow"]
    },
    {
      "patterns": ["\\bshop\\b", "\\bcheckout\\b"],
      "add": ["checkout_flow"]
    }
  ],
  "metadata": {
    "canonicalProjectFolder": "Websites_Apps",
    "recommendedDriveFolder": "Websites_Apps",
    "domain": "websites-and-apps",
    "designLanguage": "square-first",
    "shapePolicy": "no-pills",
    "forbiddenUiPatterns": [
      "pill buttons",
      "pill nav items",
      "pill tags",
      "capsule shells"
    ]
  }
}
